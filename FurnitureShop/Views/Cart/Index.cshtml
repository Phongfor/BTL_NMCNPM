@model List<FurnitureShop.DTO.CartItemDTO>
@{
    ViewData["Title"] = "Giỏ hàng";
}

<section class="cart-section">
    <div class="container">
        <h2 style="font-size:28px;color:var(--brown);margin-bottom:28px">Giỏ hàng của bạn</h2>
        @if (Model != null && Model.Count > 0)
        {
            <div class="cart-layout">
                <div>
                    <table class="cart-table">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Đơn giá</th>
                                <th>Số lượng</th>
                                <th>Thành tiền</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="cart-product">
                                            <img src="@item.ImageURL" alt="@item.ProductName"
                                                 onerror="this.src='/images/no-image.jpg'" />
                                            <span class="cart-product-name">@item.ProductName</span>
                                        </div>
                                    </td>
                                    <td>@item.Price.ToString("N0") ₫</td>
                                    <td>
                                        <form asp-controller="Cart" asp-action="UpdateQuantity"
                                              method="post" class="qty-control">
                                            <input type="hidden" name="productId" value="@item.ProductID" />
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" />
                                            <button type="submit">✓</button>
                                        </form>
                                    </td>
                                    <td><strong>@item.SubTotal.ToString("N0") ₫</strong></td>
                                    <td>
                                        <form asp-controller="Cart" asp-action="Remove" method="post">
                                            <input type="hidden" name="productId" value="@item.ProductID" />
                                            <button type="submit" class="btn-danger">Xóa</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a asp-controller="Product" asp-action="Index"
                       class="btn-outline" style="display:inline-block;margin-top:16px">← Tiếp tục mua sắm</a>
                </div>
                <div class="cart-summary">
                    <h3>Tóm tắt đơn hàng</h3>
                    <div class="summary-row">
                        <span>Số sản phẩm:</span><span>@ViewBag.CartCount</span>
                    </div>
                    <div class="summary-row summary-total">
                        <span>Tổng tiền:</span><span>@ViewBag.Total.ToString("N0") ₫</span>
                    </div>
                    <a asp-controller="Order" asp-action="Checkout" class="btn-primary">
                        Tiến hành đặt hàng →
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="empty-cart">
                <p style="font-size:48px;margin-bottom:16px">🛒</p>
                <p>Giỏ hàng của bạn đang trống.</p>
                <a asp-controller="Product" asp-action="Index"
                   class="btn-primary" style="display:inline-block;margin-top:20px">Mua sắm ngay</a>
            </div>
        }
    </div>
</section>