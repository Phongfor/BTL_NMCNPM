@model List<FurnitureShop.DTO.CategoryDTO>
@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
    <!-- DANH SÁCH -->
    <div class="admin-table-wrap">
        <div class="admin-table-header"><h3>Danh sách danh mục</h3></div>
        <table class="admin-table">
            <thead><tr><th>ID</th><th>Tên danh mục</th><th>Mô tả</th><th>Thao tác</th></tr></thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td>@cat.CategoryID</td>
                        <td><strong>@cat.CategoryName</strong></td>
                        <td>@cat.Description</td>
                        <td>
                            <form action="/Admin/CategoryAdmin/Delete" method="post"
                                  style="display:inline"
                                  onsubmit="return confirm('Xóa danh mục này?')">
                                <input type="hidden" name="id" value="@cat.CategoryID" />
                                <button type="submit" class="btn-sm btn-delete">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- THÊM MỚI -->
    <div class="card-admin">
        <h3>Thêm danh mục mới</h3>
        <form action="/Admin/CategoryAdmin/Create" method="post"
              enctype="multipart/form-data" class="admin-form">
            <div class="form-group">
                <label>Tên danh mục <span style="color:red">*</span></label>
                <input type="text" name="CategoryName" placeholder="VD: Phòng khách" required />
            </div>
            <div class="form-group">
                <label>Mô tả</label>
                <input type="text" name="Description" placeholder="Mô tả ngắn về danh mục" />
            </div>
            <div class="form-group">
                <label>Ảnh danh mục</label>
                <input type="file" name="imageFile" accept="image/*"
                       style="padding:6px;border:1px solid #ccc;border-radius:8px;width:100%" />
            </div>
            <button type="submit" class="btn-primary-sm">Thêm danh mục</button>
        </form>
    </div>
</div>